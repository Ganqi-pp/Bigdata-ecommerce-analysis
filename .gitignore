# 大数据文件（CSV 数据文件可能较大）
*.csv
*.zip
*.gz

# Python 虚拟环境
kafka_env/
pyflink_env/
__pycache__/
*.pyc

# Docker 数据卷（如果有本地挂载数据）
volumes/
data/

# 日志文件
*.log

# IDE 配置
.vscode/
.idea/

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
tmp/
*.tmp

# 注意：lib 下的 jar 文件可能较大，但如果你希望保留（用于直接部署），可以上传。如果超过 GitHub 文件限制（100MB），需要 Git LFS。这里先排除 jar（或单独处理）
lib/*.jar
